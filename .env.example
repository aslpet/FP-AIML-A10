# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini
# GEMINI_API_KEY wajib. Tiga key per-peran opsional (fallback ke GEMINI_API_KEY).
GEMINI_API_KEY=
GEMINI_API_KEY_PIPELINE=
GEMINI_API_KEY_PERSONA=
GEMINI_API_KEY_EVALUATOR=
# Pastikan ID model VALID & aktif untuk key kamu (default kode: gemini-2.0-flash).
MODEL_PIPELINE=gemini-2.0-flash
MODEL_PERSONA=gemini-2.0-flash
MODEL_EVALUATOR=gemini-2.0-flash

# Pipeline
RSS_FEEDS_JSON={"politik_hukum":["https://www.cnnindonesia.com/nasional/rss","https://rss.tempo.co/politik"],"ekonomi":["https://www.cnnindonesia.com/ekonomi/rss"],"teknologi":["https://www.cnnindonesia.com/teknologi/rss"],"sosial_pendidikan":["https://www.antaranews.com/rss/humaniora.xml","https://www.republika.co.id/rss/pendidikan"],"lingkungan":["https://www.mongabay.co.id/feed"]}
DAILY_ACTIVE_CATEGORIES=4
QUEUE_TTL_DAYS=3
REPORT_RETIRE_THRESHOLD=3
CRON_SECRET=generate-a-strong-random-secret

# IndoBERT (opsional)
INDOBERT_SERVICE_URL=